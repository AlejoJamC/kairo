{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../../packages/env/**"],
      "outputs": ["dist/**", ".next/**", "out/**", "public/dashboard/**", "!.next/cache/**"]
    },
    "build:api": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../../packages/env/**"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", "../../packages/env/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "clean": {
      "cache": false
    },
    "@kairo/dashboard#build": {
      "env": ["VITE_SUPABASE_URL", "VITE_SUPABASE_ANON_KEY"],
      "outputs": ["dist/**"]
    },
    "@kairo/landing#build": {
      "dependsOn": ["@kairo/dashboard#build"],
      "env": ["GOOGLE_CLIENT_SECRET"],
      "outputs": [".next/**", "!.next/cache/**", "public/dashboard/**"]
    }
  }
}
