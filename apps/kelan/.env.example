# Kelan — Internal Backoffice
# Copy this to .env.local and fill in the values.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Same Supabase project as the main Kairo app.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Kelan ─────────────────────────────────────────────────────────────────────
# Full URL of this app (used to construct OAuth callback URL).
# Local: http://localhost:3002
# Production: https://kelan.alejojamc.com
NEXT_PUBLIC_KELAN_URL=http://localhost:3002
