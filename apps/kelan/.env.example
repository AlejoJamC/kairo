# Kelan — Internal Backoffice
# Copy this to .env.local and fill in the values.
# All vars (except NEXT_PUBLIC_*) are server-only and must NEVER be
# exposed to the client or committed to source control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Same Supabase project as the main Kairo app.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service role key — bypasses ALL RLS. Server-side only. Never NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Kelan ─────────────────────────────────────────────────────────────────────
# Full URL of this app (used to construct OAuth callback URL).
# Local: http://localhost:3002
# Production: https://kelan.alejojamc.com
NEXT_PUBLIC_KELAN_URL=http://localhost:3002

# Optional comma-separated email allowlist (secondary safeguard).
# If set, only emails in this list can complete admin login even if
# they exist in admin_users. Leave empty to rely solely on admin_users table.
# KELAN_ADMIN_EMAILS=alejandromantilla7@hotmail.com,other@example.com
