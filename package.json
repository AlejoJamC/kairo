{
  "name": "kairo-monorepo",
  "devDependencies": {
    "turbo": "^2.9.9",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.13",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=@kairo/dashboard --filter=@kairo/landing --filter=@kairo/api --filter=@kairo/kelan",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "SKIP_LLM_INTEGRATION=1 bun test apps/api packages/intelligence && turbo run test --filter=@kairo/dashboard",
    "clean": "turbo run clean"
  },
  "workspaces": ["apps/*", "packages/*"]
}
