# =================================================================
# Kairo — single root .env.local for the entire monorepo
#
# cp .env.example .env.local  (fill in real values, never commit)
#
# How each app reads this file:
#   apps/dashboard — Vite envDir set to "../../" so it reads from here
#   apps/landing — Next.js traverses up to the monorepo root
#
# Validated by packages/env/index.ts (shared) and each app's env.ts.
# Never access process.env or import.meta.env directly — use env.ts.
# =================================================================

# === SHARED (packages/env) =======================================
# Validated for: api, landing (server-side)

# Supabase project URL — server-side usage
SUPABASE_URL=https://your-project.supabase.co

# LLM provider: claude | ollama (default: ollama)
INTELLIGENCE_PROVIDER=ollama

# Anthropic API key — required only when INTELLIGENCE_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# GOOGLE OAUTH client secret — server-only, NEVER expose to the client
GOOGLE_CLIENT_SECRET=your-google-client-secret

# KAI-248: cron interval (minutes) for the Gmail history.list poll fan-out (default: 5)
# GMAIL_POLL_CRON_INTERVAL_MINUTES=5

# === FEATURE FLAGS (packages/feature-flags) =======================
# Override any flag with FEATURE_FLAG_<UPPER_SNAKE_NAME>=true|false
# Default is always OFF (false) unless overridden here.

# KAI-201: show real-time detection UI in the onboarding wizard (step 2)
# When OFF (default): wizard skips detect step → goes straight to company-name form
# When ON: shows live classification metrics polled from /bff/classification/progress
# FEATURE_FLAG_ENABLE_DETECTION_UI=true

# KAI-246: send acknowledgement.html on new ticket creation via outbox
# When OFF (default): customer doesn't get auto-confirmation with ticket number (KAI-T-n)
# When ON: sends "Kairo Support" template immediately on was_created=true, skips out-of-hours reply
# FEATURE_FLAG_ENABLE_TICKET_ACKNOWLEDGEMENT=true

# === LANDING (apps/landing) ======================================
# Validated by apps/landing/env.ts via @t3-oss/env-nextjs

# Supabase public vars (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# Google OAuth client ID (safe to expose to the browser)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Base URL of the landing/auth app (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Where to send users after login — /dashboard in prod, Vite URL in dev
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:5173/dashboard/

# === DASHBOARD (apps/dashboard) ===================================
# Validated by apps/dashboard/src/env.ts via @t3-oss/env-core

# Supabase public vars (Vite exposes VITE_* to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Landing URL for cross-app redirects — empty in prod (same origin)
VITE_LANDING_URL=http://localhost:3000

# Feature flags (Vite — defaults to false if not defined)
# KAI-249: enable the Escalation flow tab (Tab 4) in the right panel
# VITE_ENABLE_ESCALATE_TAB=true
