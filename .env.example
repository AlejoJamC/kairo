# =================================================================
# Kairo — single root .env.local for the entire monorepo
#
# cp .env.example .env.local  (fill in real values, never commit)
#
# How each app reads this file:
#   apps/dashboard — Vite envDir set to "../../" so it reads from here
#   apps/landing — Next.js traverses up to the monorepo root
#
# Validated by packages/env/index.ts (shared) and each app's env.ts.
# Never access process.env or import.meta.env directly — use env.ts.
# =================================================================

# === SHARED (packages/env) =======================================
# Validated for: api, landing (server-side)

# Supabase project URL — server-side usage
SUPABASE_URL=https://your-project.supabase.co

# LLM provider: claude | ollama (default: ollama)
INTELLIGENCE_PROVIDER=ollama

# Anthropic API key — required only when INTELLIGENCE_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# GOOGLE OAUTH client secret — server-only, NEVER expose to the client
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === FEATURE FLAGS (packages/feature-flags) =======================
#
# Server-side, boolean (runtime-overrideable):
#   FEATURE_FLAG_<UPPER_SNAKE_NAME>=true|false
#   Defaults: false unless overridden here.
#
# Server-side, numeric (runtime-overrideable):
#   FEATURE_FLAG_<UPPER_SNAKE_NAME>=<positive integer>
#   Defaults: see packages/feature-flags/src/flags.ts. Invalid/unset → default.
#
# Client-side (build-time, Vite/framework-compiled):
#   VITE_FF_<UPPER_SNAKE_NAME>=true|false
#   Defaults: false unless overridden here.
#   Used by SPA clients that can't access process.env at runtime.
#
# Client-side, numeric (build-time, Vite/framework-compiled):
#   VITE_FF_<UPPER_SNAKE_NAME>=<positive integer>
#   Defaults: see apps/dashboard/src/lib/feature-flags.ts. Invalid/unset → default.
#   Baked in at build time — a new value only takes effect on the next deploy.

# KAI-201: show real-time detection UI in the onboarding wizard (step 2)
# When OFF (default): wizard skips detect step → goes straight to company-name form
# When ON: shows live classification metrics polled from /bff/classification/progress
# FEATURE_FLAG_ENABLE_DETECTION_UI=true

# KAI-246: send acknowledgement.html on new ticket creation via outbox
# When OFF (default): customer doesn't get auto-confirmation with ticket number (KAI-T-n)
# When ON: sends "Kairo Support" template immediately on was_created=true, skips out-of-hours reply
# FEATURE_FLAG_ENABLE_TICKET_ACKNOWLEDGEMENT=true

# KAI-248: how often (in minutes) the Gmail history.list poll cron fans out
# one event per active Gmail integration. Default: 5. The cron schedule is
# registered at app startup, so a new value takes effect on the next deploy/restart.
# FEATURE_FLAG_GMAIL_POLL_CRON_INTERVAL_MINUTES=5

# === LANDING (apps/landing) ======================================
# Validated by apps/landing/env.ts via @t3-oss/env-nextjs

# Supabase public vars (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# Google OAuth client ID (safe to expose to the browser)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Base URL of the landing/auth app (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Where to send users after login — /dashboard in prod, Vite URL in dev
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:5173/dashboard/

# === DASHBOARD (apps/dashboard) ===================================
# Validated by apps/dashboard/src/env.ts via @t3-oss/env-core

# Supabase public vars (Vite exposes VITE_* to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Landing URL for cross-app redirects — empty in prod (same origin)
VITE_LANDING_URL=http://localhost:3000

# Client-side feature flags (build-time, VITE_FF_*)
# These are compiled at build time by Vite and cannot be changed at runtime.
# Default: false (disabled) — uncomment to enable.

# ╔════════════════════════════════════════════════════════════════════════════╗
# ║ Dashboard → Right Panel — Triage Ticket Tabs                               ║
# ╚════════════════════════════════════════════════════════════════════════════╝
#
# Each tab can be independently enabled/disabled. When disabled, the tab does
# not appear in the UI and is not loaded. Default is OFF (false).

# Tab 0: AI Assistant — Copilot chat for ticket resolution (KAI-249)
# VITE_FF_ENABLE_ASSISTANT_TAB=true

# Tab 1: Client Profile — Customer details, contact info, KPIs
# VITE_FF_ENABLE_CLIENT_TAB=true

# Tab 2: Similar Tickets — Semantic search for related resolved cases
# VITE_FF_ENABLE_SIMILAR_TAB=true

# Tab 3: Knowledge Base — Article recommendations from internal KB
# VITE_FF_ENABLE_ARTICLES_TAB=true

# Tab 4: Escalation Flow — Escalation reasons, severity, recommendation (KAI-249)
# VITE_FF_ENABLE_ESCALATE_TAB=true

# Ticket grouping (KAI-24) — triage left panel: multi-select checkboxes,
# "Agrupar seleccionados" action bar, AI similarity suggestion callout and
# the grouped-tickets badge on cards. OFF unless exactly "true"; safe unset.
# VITE_FF_ENABLE_TICKET_GROUPING=true

# Tab order (optional) — comma-separated tab ids, defines display order in the
# tab bar. Does NOT enable/disable anything — only reorders tabs that are
# already enabled above. Any enabled tab not listed here is appended at the
# end, in the order coded in ai-assistant.tsx. Unset → order stays as coded.
# Valid ids: assistant, client, similar, articles, escalate
# VITE_FF_RIGHT_PANEL_TAB_ORDER=client,escalate,assistant

# "Assign to me" button (ticket header) — OFF unless exactly "true"; safe unset.
# VITE_FF_ENABLE_ASSIGN_TO_ME=true

# KAI-177: how often (in seconds) the sidebar polls /api/v1/sidebar/counts for
# the nav badge counts (Triage/Resuelto/etc.). Default: 20. Invalid/unset → default.
# VITE_FF_SIDEBAR_COUNTS_POLL_INTERVAL_SECONDS=20
